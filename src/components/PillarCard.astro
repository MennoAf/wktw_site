---
interface Props {
  title: string;
  tool: string;
  description: string;
  href: string;
  icon: string;
}

const { title, tool, description, href, icon } = Astro.props;
const normalizedHref = href.startsWith('/') && href !== '/' ? `${href.replace(/\/+$/, '')}/` : href;
---

<a href={normalizedHref} class="group block plate plate-hover p-8">
  <div
    class="w-12 h-12 rounded-xl border border-gilt-dim/40 bg-bg-inset/60 flex items-center justify-center text-2xl text-gilt mb-5"
    aria-hidden="true"
  >
    {icon}
  </div>
  <h3 class="text-xl mb-2 group-hover:text-gilt-bright transition-colors">{title}</h3>
  <p class="eyebrow text-xs mb-4">Powered by {tool}</p>
  <p class="text-secondary-text text-base leading-relaxed">{description}</p>
  <span class="inline-block mt-5 text-accent text-sm font-medium group-hover:translate-x-1 transition-transform">
    Learn more &rarr;
  </span>
</a>
