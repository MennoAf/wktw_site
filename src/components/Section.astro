---
interface Props {
  id?: string;
  class?: string;
  elevated?: boolean;
}

const { id, class: className, elevated = false } = Astro.props;
---

<section
  id={id}
  class:list={[
    'py-20 px-6',
    elevated && 'bg-bg-elevated',
    className,
  ]}
>
  <div class="max-w-7xl mx-auto">
    <slot />
  </div>
</section>
