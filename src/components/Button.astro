---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { href, variant = 'primary', class: className } = Astro.props;
const normalizedHref =
  href.startsWith('/') && href !== '/' && !href.includes('#') && !href.includes('?') && !href.includes('.')
    ? `${href.replace(/\/+$/, '')}/`
    : href;
---

<a
  href={normalizedHref}
  class:list={[
    'btn',
    variant === 'primary' ? 'btn-gold' : 'btn-outline',
    className,
  ]}
>
  <slot />
</a>
