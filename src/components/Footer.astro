---
const services = [
  { label: 'The Get Right', href: '/the-get-right' },
  { label: 'Free Scan', href: '/scan' },
  { label: 'Platform Audit', href: '/the-get-right/platform' },
  { label: 'Content Audit', href: '/the-get-right/content' },
  { label: 'Revenue Audit', href: '/the-get-right/revenue' },
];

const insights = [
  { label: 'Latest Posts', href: '/insights' },
  { label: 'Technical Debt', href: '/insights/category/technical-debt' },
  { label: 'Content Strategy', href: '/insights/category/content-strategy' },
  { label: 'Analytics', href: '/insights/category/analytics' },
];

const company = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Proof', href: '/proof' },
  { label: 'Privacy', href: '/legal/privacy' },
  { label: 'Terms', href: '/legal/terms' },
];
---

<footer class="border-t border-border-subtle bg-bg-surface mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-primary-text font-heading font-bold text-xl tracking-tight">
          WKTW
        </a>
        <p class="mt-3 text-secondary-text text-sm leading-relaxed">
          Systems-driven growth agency. We built the tools. We run the tools. You talk to us.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-primary-text font-body font-semibold text-sm uppercase tracking-wider mb-4">
          Services
        </h4>
        <ul class="space-y-2.5">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-secondary-text text-sm hover:text-primary-text transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Insights -->
      <div>
        <h4 class="text-primary-text font-body font-semibold text-sm uppercase tracking-wider mb-4">
          Insights
        </h4>
        <ul class="space-y-2.5">
          {insights.map((item) => (
            <li>
              <a href={item.href} class="text-secondary-text text-sm hover:text-primary-text transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-primary-text font-body font-semibold text-sm uppercase tracking-wider mb-4">
          Company
        </h4>
        <ul class="space-y-2.5">
          {company.map((item) => (
            <li>
              <a href={item.href} class="text-secondary-text text-sm hover:text-primary-text transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border-subtle text-secondary-text text-sm">
      &copy; {new Date().getFullYear()} We Know The Why. All rights reserved.
    </div>
  </div>
</footer>
