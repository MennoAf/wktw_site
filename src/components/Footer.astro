---
import { features } from '../data/features';

const services = [
  { label: 'The Get Right', href: '/the-get-right' },
  { label: 'Platform Audit', href: '/the-get-right/platform' },
  { label: 'Content Audit', href: '/the-get-right/content' },
  { label: 'Revenue Audit', href: '/the-get-right/revenue' },
];

const company = [
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
  { label: 'Proof', href: '/proof' },
  { label: 'Insights', href: '/insights' },
  ...(features.search ? [{ label: 'Search', href: '/search' }] : []),
  { label: 'Privacy', href: '/legal/privacy' },
  { label: 'Terms', href: '/legal/terms' },
];
---

<footer class="border-t border-border-subtle bg-bg-surface mt-24">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-primary-text font-heading font-bold text-xl tracking-tight">
          WKTW
        </a>
        <p class="mt-3 text-secondary-text text-sm leading-relaxed">
          Systems-driven growth agency. We built the tools. We run the tools. You talk to us.
        </p>
        <a
          href="mailto:jon@weknowthewhy.com"
          class="inline-flex items-center min-h-[44px] mt-2 text-accent text-sm hover:text-accent-hover transition-colors"
        >
          jon@weknowthewhy.com
        </a>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-primary-text font-body font-semibold text-sm uppercase tracking-wider mb-4">
          Services
        </h3>
        <ul class="space-y-0.5">
          {services.map((item) => (
            <li>
              <a href={item.href} class="inline-flex items-center min-h-[44px] text-secondary-text text-sm hover:text-primary-text transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-primary-text font-body font-semibold text-sm uppercase tracking-wider mb-4">
          Company
        </h3>
        <ul class="space-y-0.5">
          {company.map((item) => (
            <li>
              <a href={item.href} class="inline-flex items-center min-h-[44px] text-secondary-text text-sm hover:text-primary-text transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border-subtle flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-secondary-text text-sm">
      <p>&copy; {new Date().getFullYear()} We Know The Why. All rights reserved.</p>
      <button
        type="button"
        onclick="window.wktwOpenConsent && window.wktwOpenConsent()"
        class="inline-flex items-center min-h-[44px] text-secondary-text text-sm hover:text-primary-text transition-colors text-left sm:text-right"
      >
        Cookie settings
      </button>
    </div>
  </div>
</footer>
