---
// Social share links for insights articles (WL-18 / conversion-ux-social-share-1).
//
// Pure anchor links — no JavaScript, no clipboard API, so nothing for the CSP
// to nonce and no extra script weight. Gated by features.socialShare upstream.
interface Props {
  /** Absolute canonical URL of the article being shared. */
  url: string;
  /** Article title, used as the pre-filled share text/subject. */
  title: string;
}

const { url, title } = Astro.props;

const enc = encodeURIComponent;
const links = [
  {
    label: 'Share on X',
    short: 'X',
    href: `https://twitter.com/intent/tweet?url=${enc(url)}&text=${enc(title)}`,
  },
  {
    label: 'Share on LinkedIn',
    short: 'LinkedIn',
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${enc(url)}`,
  },
  {
    label: 'Share by email',
    short: 'Email',
    href: `mailto:?subject=${enc(title)}&body=${enc(url)}`,
  },
];
---

<div class="mt-12 pt-8 border-t border-border-subtle flex flex-wrap items-center gap-3">
  <span class="text-secondary-text text-sm font-medium">Share this</span>
  <ul class="flex flex-wrap gap-2">
    {links.map((link) => (
      <li>
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          class="inline-flex items-center min-h-[44px] px-4 rounded-lg border border-border-subtle text-secondary-text text-sm font-medium hover:border-accent hover:text-accent transition-colors"
        >
          {link.short}
        </a>
      </li>
    ))}
  </ul>
</div>
