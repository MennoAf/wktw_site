---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  breadcrumb?: boolean;
}

const { title, description, ogImage = '/og-default.png', noindex = false, breadcrumb = true } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Consent Mode v2 — defaults denied, must run before GTM -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'denied',
        personalization_storage: 'denied',
        security_storage: 'granted',
        wait_for_update: 500
      });
      try {
        if (localStorage.getItem('wktw-consent') === 'granted') {
          gtag('consent', 'update', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
            analytics_storage: 'granted'
          });
        }
      } catch (e) {}
    </script>
    <!-- End Google Consent Mode v2 -->

    <!-- Google Tag Manager — deferred until consent (WL-02). Consent Mode v2 above
         denies storage by default; this also withholds the GTM *script itself* until
         the visitor accepts (or accepted on a prior visit). The banner calls
         window.wktwLoadGTM() on Accept. -->
    <script is:inline>
      (function () {
        var loaded = false;
        window.wktwLoadGTM = function () {
          if (loaded) return;
          loaded = true;
          (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
          new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
          j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
          'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
          })(window,document,'script','dataLayer','GTM-5VQTG6TH');
        };
        try {
          if (localStorage.getItem('wktw-consent') === 'granted') window.wktwLoadGTM();
        } catch (e) {}
      })();
    </script>
    <!-- End Google Tag Manager -->

    <title>{title} | WKTW</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Fonts: self-hosted (see @font-face in global.css). Preload the latin body +
         heading cuts that render above the fold; remaining subsets load on demand. -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/lora-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#2C211D" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | WKTW`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | WKTW`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Structured Data: Organization (sitewide) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://weknowthewhy.com/#organization",
      "name": "We Know The Why",
      "alternateName": "WKTW",
      "url": "https://weknowthewhy.com",
      "logo": "https://weknowthewhy.com/og-default.png",
      "description": "Systems-driven growth agency. We built the tools. We run the tools. You talk to us.",
      "numberOfEmployees": { "@type": "QuantitativeValue", "value": 3 },
      "founder": [
        { "@type": "Person", "@id": "https://weknowthewhy.com/about#jon-lister" },
        { "@type": "Person", "@id": "https://weknowthewhy.com/about#jason-bauman" },
        { "@type": "Person", "@id": "https://weknowthewhy.com/about#brandon-griner" },
      ],
      "knowsAbout": [
        "Search Engine Optimization",
        "Generative Engine Optimization",
        "Answer Engine Optimization",
        "Technical SEO",
        "Content Strategy",
        "Web Performance",
        "Conversion Rate Optimization",
        "Web Analytics",
      ],
    })} />

    <!-- Privacy-friendly analytics by Plausible -->
    <script is:inline async src="https://plausible.io/js/pa-GNbSMJlnmKdl4_QO4sS4C.js"></script>
    <script is:inline>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- No GTM <noscript> fallback by design: a no-JS visitor can't operate the
         consent banner, so firing GTM for them would be pre-consent tracking (WL-02). -->
    <Header />
    {breadcrumb && <Breadcrumb />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <ConsentBanner />
  </body>
</html>
