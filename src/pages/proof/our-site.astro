---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Button from '../../components/Button.astro';
---

<BaseLayout
  title="We Audited Our Own Site"
  description="Full Muttr, Canary, and Delphi audit results for weknowthewhy.com. What we found, what we fixed, full transparency."
>
  <Section band="deep" class="pt-24 pb-20">
    <div class="max-w-3xl">
      <p class="eyebrow mb-4">Proof &rsaquo; Self-Audit</p>
      <h1 class="mb-6">We audited our own site.</h1>
      <p class="text-secondary-text text-xl leading-relaxed mb-6">
        We run Muttr, Canary, and Delphi against weknowthewhy.com using the same
        configuration and standards we apply to client sites. Here are the real results.
      </p>
      <p class="text-secondary-text text-sm">
        Last updated: <span class="text-primary-text">Coming soon &mdash; this page will be populated after Phase 2</span>
      </p>
    </div>
  </Section>

  <!-- Muttr Results -->
  <Section elevated>
    <h2 class="mb-6">Platform Technical Audit (Muttr)</h2>
    <div class="plate p-8">
      <p class="text-secondary-text text-center py-8">
        Audit results will be published here after the site is live and Muttr has been run against it.
        Check back after launch.
      </p>
    </div>
  </Section>

  <!-- Canary Results -->
  <Section>
    <h2 class="mb-6">Content Authority Audit (Canary)</h2>
    <div class="plate p-8">
      <p class="text-secondary-text text-center py-8">
        Content audit results will be published here once the insights section is live
        and Canary has been run against the site's topic coverage.
      </p>
    </div>
  </Section>

  <!-- Delphi Results -->
  <Section elevated>
    <h2 class="mb-6">Revenue Performance Audit (Delphi)</h2>
    <div class="plate p-8">
      <p class="text-secondary-text text-center py-8">
        Analytics audit results will be published here once measurement is established
        and Delphi has verified the analytics implementation.
      </p>
    </div>
  </Section>

  <Section band="deep">
    <div class="text-center">
      <h2 class="mb-4">Want to see what we'd find on yours?</h2>
      <p class="text-secondary-text text-lg mb-8">
        We apply the same rigor to every site we audit. Talk to a founder about
        what we'd find on yours.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <Button href="/contact">Talk to a Founder</Button>
        <Button href="/the-get-right" variant="secondary">Learn About The Get Right</Button>
      </div>
    </div>
  </Section>

  <!-- Structured Data: the self-audit results page as a WebPage tied to the
       sitewide Organization. Describes the three audits we run on ourselves;
       no Rating/Review nodes until real, attributable results are published (WL-17). -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://weknowthewhy.com/proof/our-site",
    "url": "https://weknowthewhy.com/proof/our-site",
    "name": "We Audited Our Own Site",
    "description": "Full Muttr, Canary, and Delphi audit results for weknowthewhy.com. What we found, what we fixed, full transparency.",
    "about": { "@id": "https://weknowthewhy.com/#organization" },
    "publisher": { "@id": "https://weknowthewhy.com/#organization" },
    "isPartOf": { "@id": "https://weknowthewhy.com/proof" },
    "significantLink": [
      "https://weknowthewhy.com/the-get-right/platform",
      "https://weknowthewhy.com/the-get-right/content",
      "https://weknowthewhy.com/the-get-right/revenue",
    ],
  })} />
</BaseLayout>
