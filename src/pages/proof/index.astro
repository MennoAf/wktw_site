---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
---

<BaseLayout
  title="Proof"
  description="We audit our own site with our own tools. Same standards, full transparency. See the results."
>
  <Section band="deep" class="pt-24 pb-20">
    <div class="max-w-3xl">
      <p class="eyebrow mb-5">Proof</p>
      <h1 class="mb-6">We prove it.</h1>
      <p class="text-secondary-text text-xl leading-relaxed">
        We tell clients their sites have problems. So we run our own tools on ours.
        Same standards. Full transparency. Below you'll find our own audit results
        and, as we earn them, client case studies.
      </p>
    </div>
  </Section>

  <Section elevated>
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Self-audit card (always first) -->
      <a
        href="/proof/our-site"
        class="group block plate plate-hover p-8"
      >
        <div class="eyebrow text-xs mb-2">Self-Audit</div>
        <h3 class="text-xl mb-3 group-hover:text-gilt-bright transition-colors">
          We audited our own site
        </h3>
        <p class="text-secondary-text mb-4">
          Muttr, Canary, and Delphi results for weknowthewhy.com. What we found,
          what we fixed, and what we chose to accept.
        </p>
        <span class="text-accent text-sm font-medium group-hover:translate-x-1 transition-transform inline-block">
          See the results &rarr;
        </span>
      </a>

      <!-- Placeholder for future case studies -->
      <div class="border border-gilt-dim/30 border-dashed rounded-2xl p-8 flex items-center justify-center">
        <p class="text-secondary-text text-center">
          Client case studies coming soon.<br />
          <a href="/contact" class="text-accent text-sm hover:text-accent-hover">Be our first &rarr;</a>
        </p>
      </div>
    </div>
  </Section>

  <!-- Structured Data: the Proof index is a CollectionPage about our own
       transparency — links the page into the graph via the sitewide Organization
       and its one published self-audit. No Review/Rating nodes: we don't fabricate
       testimonials we haven't earned (WL-17). -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": "https://weknowthewhy.com/proof",
    "url": "https://weknowthewhy.com/proof",
    "name": "Proof",
    "description": "We audit our own site with our own tools. Same standards, full transparency. See the results.",
    "about": { "@id": "https://weknowthewhy.com/#organization" },
    "publisher": { "@id": "https://weknowthewhy.com/#organization" },
    "hasPart": [
      {
        "@type": "WebPage",
        "@id": "https://weknowthewhy.com/proof/our-site",
        "url": "https://weknowthewhy.com/proof/our-site",
        "name": "We Audited Our Own Site",
      },
    ],
  })} />
</BaseLayout>
