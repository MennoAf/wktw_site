---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

// This page is statically prerendered, so Astro.url.searchParams is empty at
// build time — we can't branch the copy server-side. Render the contact variant
// by default and let the inline script swap to the scan variant at runtime based
// on the live ?type= param (contact -> /thanks, scan -> /thanks?type=scan).
const copy = {
  contact: {
    heading: 'Message received.',
    body: "A founder will reply within 24 hours. No sales team, no account manager — the response comes from the person who'll do the work.",
  },
  scan: {
    heading: 'Scan request received.',
    body: "We'll run the structural audit and email your top findings within 24-48 hours. No credit card, no follow-up sales sequence — just the report.",
  },
};
---

<BaseLayout
  title="Thanks"
  description="We've received your submission and will be in touch shortly."
>
  <Section class="pt-28 pb-24">
    <div class="max-w-2xl mx-auto">
      <p class="text-accent font-mono text-sm uppercase tracking-wider mb-4">
        ✓ Submitted
      </p>
      <h1 id="thanks-heading" class="mb-6">{copy.contact.heading}</h1>
      <p id="thanks-body" class="text-secondary-text text-xl leading-relaxed mb-10">
        {copy.contact.body}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/"
          class="bg-accent text-on-primary px-6 py-3 rounded-lg font-semibold hover:bg-accent-hover transition-colors text-center"
        >
          Back to homepage &rarr;
        </a>
        <a
          href="/the-get-right"
          class="border border-border-subtle text-primary-text px-6 py-3 rounded-lg font-semibold hover:border-accent hover:text-accent transition-colors text-center"
        >
          Learn about The Get Right &rarr;
        </a>
      </div>
    </div>
  </Section>

  <!-- Runtime branch: this static page renders the contact variant by default;
       one read of ?type= drives both (a) swapping in the scan copy and (b) the
       WL-23 generate_lead conversion event. The push self-gates on consent — a
       no-op if GTM isn't loaded; the GA4 tag that consumes it is GTM-side (Brandon). -->
  <script is:inline define:vars={{ copy }}>
    var formType = new URLSearchParams(window.location.search).get('type') === 'scan' ? 'scan' : 'contact';
    if (formType === 'scan') {
      var h = document.getElementById('thanks-heading');
      var b = document.getElementById('thanks-body');
      if (h) h.textContent = copy.scan.heading;
      if (b) b.textContent = copy.scan.body;
    }
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({ event: 'generate_lead', form_type: formType });
  </script>
</BaseLayout>
