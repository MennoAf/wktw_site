---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="404 — Page Not Found"
  description="This page either moved, never existed, or got pruned in an audit. Let's get you somewhere that actually helps."
>
  <Section class="pt-28 pb-24">
    <div class="max-w-2xl mx-auto">
      <p class="font-heading font-bold text-accent leading-none tracking-tight text-[8rem] md:text-[10rem] mb-2">
        404
      </p>
      <h1 class="mb-6">We don't know the why on this one.</h1>
      <p class="text-secondary-text text-xl leading-relaxed mb-10">
        This page either moved, never existed, or got pruned in an audit.
        Let's get you somewhere that actually helps.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mb-8">
        <a
          href="/the-get-right"
          class="bg-accent text-on-primary px-6 py-3 rounded-lg font-semibold hover:bg-accent-hover transition-colors text-center"
        >
          See what we do &rarr;
        </a>
        <a
          href="/contact"
          class="border border-border-subtle text-primary-text px-6 py-3 rounded-lg font-semibold hover:border-accent hover:text-accent transition-colors text-center"
        >
          Talk to us &rarr;
        </a>
      </div>

      <p class="text-secondary-text text-sm">
        Or jump back to the <a href="/" class="text-accent hover:text-accent-hover">homepage</a>.
      </p>
    </div>
  </Section>
</BaseLayout>
