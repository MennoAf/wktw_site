          "Content Strategy",
        ],
        "worksFor": { "@id": "https://weknowthewhy.com/#organization" },
        "sameAs": [
          "https://www.linkedin.com/in/jonathanlister1/",
        ],
      },
      {
        "@type": "Person",
        "@id": "https://weknowthewhy.com/about#jason-bauman",
        "name": "Jason Bauman",
        "givenName": "Jason",
        "familyName": "Bauman",
