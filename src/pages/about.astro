        "familyName": "Griner",
        "jobTitle": "Cofounder, WKTW",
        "description": "Cofounder of We Know The Why. SEO Technical Supervisor at Publicis Health Media. Data Engineer & AI Marketing Specialist. CS bachelor's and Data Science master's. Built the engineering layer underneath Muttr, Canary, and Delphi.",
        "url": "https://weknowthewhy.com/about#brandon-griner",
        "image": "https://weknowthewhy.com/team/brandon-griner.webp",
        "knowsAbout": [
          "Data Engineering",
          "Technical SEO",
          "Search Engine Optimization",
          "DevOps",
          "Business Intelligence",
          "Marketing Automation",
        ],
        "worksFor": { "@id": "https://weknowthewhy.com/#organization" },
        "sameAs": [
          "https://www.linkedin.com/in/brandongriner",
          "https://www.brandon-griner.com/",
        ],
      },
    ],
  })} />
</BaseLayout>
