---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import { insightsByDate, postHref } from '../../data/insights';

const posts = insightsByDate();
---

<BaseLayout
  title="Insights"
  description="Practical insights on technical debt, content strategy, analytics integrity, and what we've learned from auditing sites."
>
  <Section class="pt-28 pb-16">
    <div class="max-w-3xl">
      <h1 class="mb-6">Insights</h1>
      <p class="text-secondary-text text-xl leading-relaxed">
        What we learn from auditing sites, turned into practical knowledge.
        Technical debt, content strategy, analytics integrity, and the patterns
        we see across every engagement.
      </p>
    </div>
  </Section>

  <Section elevated>
    <div class="space-y-6">
      {posts.map((post) => (
        <a
          href={postHref(post)}
          class="group block bg-bg-surface border border-border-subtle rounded-xl p-8 hover:border-accent transition-colors"
        >
          <div class="flex flex-wrap items-center gap-3 text-secondary-text text-sm mb-3">
            <span class="text-accent font-mono">{post.tag}</span>
            <span>&middot;</span>
            <time datetime={post.date}>{post.dateLabel}</time>
            <span>&middot;</span>
            <span>{post.readingTime}</span>
          </div>
          <h2 class="text-2xl mb-3 group-hover:text-accent transition-colors">
            {post.title}
          </h2>
          <p class="text-secondary-text mb-4">{post.description}</p>
          <div class="text-secondary-text text-sm">
            <span class="text-primary-text font-medium">{post.author}</span>
            <span class="text-accent ml-4 group-hover:translate-x-1 inline-block transition-transform">
              Read &rarr;
            </span>
          </div>
        </a>
      ))}
    </div>
  </Section>
</BaseLayout>
